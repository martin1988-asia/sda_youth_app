// Firestore Rules for SDA Youth App
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- USERS ---
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Admins can manage all users
      allow list, get, update, delete: if request.auth != null && request.auth.token.role == "admin";

      // Notifications subcollection
      match /notifications/{notifId} {
        // Users can read their own notifications
        allow read: if request.auth != null && request.auth.uid == userId;

        // Notifications can only be created by system logic or admins
        allow create: if request.auth != null &&
          (
            (request.resource.data.type == "friend_request" && request.resource.data.fromUserId == request.auth.uid)
            || (request.resource.data.type == "reaction" && request.resource.data.fromUserId == request.auth.uid)
            || (request.resource.data.type == "comment" && request.resource.data.fromUserId == request.auth.uid)
            || (request.resource.data.type == "general" && request.auth.uid == userId)
            || (request.resource.data.type == "announcement" && request.auth.token.role == "admin")
            // ✅ New additions:
            || (request.resource.data.type == "post" && request.resource.data.fromUserId == request.auth.uid)
            || (request.resource.data.type == "moderation" && request.auth.token.role == "admin")
          );

        // Users can update/delete their own notifications
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- SETTINGS ---
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow list, get, update, delete: if request.auth != null && request.auth.token.role == "admin";
    }

    // --- ANNOUNCEMENTS ---
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    // --- DEVOTIONALS ---
    match /devotionals/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";

      match /reflections/{refId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // --- EVENTS ---
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.organizerId;

      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }

      match /media/{mediaId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == resource.data.organizerId;
      }
    }

    // --- GROUPS ---
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      match /media/{mediaId} {
        allow read: if request.auth != null && request.auth.uid in resource.data.memberIds;
        allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      }
    }

    // --- LESSONS ---
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";

      match /media/{mediaId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.token.role == "admin";
      }
    }

    // --- POSTS ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Owner can update/delete their own post
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;

      // Any authenticated user can update reactions or shares
      allow update: if request.auth != null && (
        request.resource.data.reactions is map ||
        request.resource.data.shares is int ||
        request.writeFields.hasOnly(['shares'])
      );

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // --- FAVORITES ---
    match /favorites/{favId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // --- MESSAGES ---
    match /messages/{messageId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.senderId;
    }

    // --- FEEDBACK ---
    match /feedback/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || request.auth.token.role == "admin"
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // --- SUPPORT ---
    match /support/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || request.auth.token.role == "admin"
      );
      allow update, delete: if request.auth != null && request.auth.token.role == "admin";
    }

    // --- MODERATION QUEUE ---
    match /moderation/{docId} {
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // --- ANALYTICS ---
    match /analytics/{docId} {
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // --- CATCH-ALL ---
    match /{collection}/{docId} {
      allow read, write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
